{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@myco/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "plugin/**/*"],
  "exclude": ["node_modules", "dist", "tests", "ui", "src/worker"]
}
